diff --git a/Frontend/jS/clearance-request-inline.js b/Frontend/jS/clearance-request-inline.js
--- a/Frontend/jS/clearance-request-inline.js
+++ b/Frontend/jS/clearance-request-inline.js
@@
   /* ===== تقديم الطلب (الإخلاء) ===== */
   async function handleClearanceSubmit() {
@@
     try {
@@
       if (window.apiClient) {
@@
         if (response.success) {
@@
           setTimeout(() => {
             window.location.href = 'employee-dashboard.html';
           }, 2000);
         }
       } else {
@@
         setTimeout(() => {
           window.location.href = 'employee-dashboard.html';
         }, 2000);
       }
     } catch (error) {
-      console.error('Clearance submission error:', error);
-      if (window.showError) {
-        window.showError('حدث خطأ أثناء إرسال الطلب');
-      }
+      console.error('Clearance submission error:', error);
+      // Offline write-through: queue for sync and show syncing banner
+      try {
+        const storageKey = 'requestsClearance';
+        const optimisticIdPrefix = 'temp-clr-';
+        const optimisticData = {
+          firstName: formData.empFirstName,
+          secondName: formData.empSecondName,
+          thirdName: formData.empThirdName,
+          employeeNumber: formData.empJobNo,
+          email: formData.empEmail,
+          department: formData.empDept,
+          jobTitle: formData.empTitle,
+          phone: formData.empMobile,
+          reason: formData.clearReason === 'أخرى' ? formData.otherReason : formData.clearReason,
+          lastWorkingDay: formData.lastWorkDay,
+          createdAt: new Date().toISOString(),
+          status: 'pending',
+          syncing: true,
+          syncFailed: false
+        };
+
+        // Insert optimistic locally
+        const list = JSON.parse(localStorage.getItem(storageKey) || '[]');
+        const optimisticId = `${optimisticIdPrefix}${Date.now()}`;
+        list.unshift({ id: optimisticId, optimisticId, ...optimisticData });
+        localStorage.setItem(storageKey, JSON.stringify(list));
+
+        // Show inline syncing banner
+        let banner = document.getElementById('sync-banner');
+        if (!banner) {
+          banner = document.createElement('div');
+          banner.id = 'sync-banner';
+          banner.textContent = '⏳ جاري المزامنة… سيتم الإرسال تلقائياً';
+          banner.style.cssText = 'margin:10px 0;padding:10px;border-radius:8px;background:#fff7ed;color:#92400e;font-weight:700;text-align:center';
+          const container = document.querySelector('.container') || document.body;
+          container.insertBefore(banner, container.firstChild);
+        }
+
+        // Schedule sync with the API
+        if (window.scheduleSync) {
+          window.scheduleSync({
+            type: 'create',
+            method: 'POST',
+            endpoint: '/employee/requests/clearance',
+            storageKey,
+            optimisticIdPrefix,
+            optimisticId,
+            data: optimisticData
+          });
+        }
+
+        if (window.showSuccess) {
+          window.showSuccess('تم حفظ الطلب وسَيتم مزامنته عند الاتصال');
+        }
+
+        // Hide banner when syncing completes
+        const onUpdated = (e) => {
+          if (!e.detail || e.detail.key !== storageKey) return;
+          const remaining = (e.detail.list || []).some(it => it.syncing);
+          if (!remaining && banner && banner.parentNode) {
+            banner.parentNode.removeChild(banner);
+            window.removeEventListener('sync:updated', onUpdated);
+          }
+        };
+        window.addEventListener('sync:updated', onUpdated);
+      } catch (e2) {
+        console.warn('Offline queue failed:', e2);
+        if (window.showError) window.showError('تعذر حفظ الطلب مؤقتاً');
+      }
     }
   }

