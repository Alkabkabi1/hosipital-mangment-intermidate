# Application
NODE_ENV=development
PORT=3037
HOST=0.0.0.0

# Database (required)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hospital_app
DB_USER=root
DB_PASSWORD=changeme
DB_CONNECTION_LIMIT=10

# Auth & tokens
JWT_SECRET=please-change-me-to-a-long-random-secret-32chars-min
ACCESS_TTL=15m
REFRESH_TTL=7d

# CORS (comma-separated origins). In development you may use *.
# Examples:
# In local dev we serve pages from the same API host/port (3037)
# List both localhost and 127.0.0.1 to avoid origin mismatches.
CORS_ALLOWED_ORIGINS=http://localhost:3037,http://127.0.0.1:3037

# Feature flags
COMMISSIONER_SERVER_ENABLED=false
UPLOAD_SCAN_ENABLED=false
TRUST_PROXY=false

# Logging & rate limit
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ENABLE_REQUEST_LOGGING=false

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=
UPLOAD_STORAGE_PATH=

# Default admin bootstrap (optional - do not use in production CI, prefer secrets)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_EMPLOYEE_NUMBER=0000
DEFAULT_ADMIN_DEPARTMENT_CODE=IT
DEFAULT_ADMIN_PHONE=0500000000
DEFAULT_ADMIN_FULL_NAME_AR=مدير النظام
DEFAULT_ADMIN_POSITION=Administrator
